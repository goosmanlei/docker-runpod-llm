FROM nvcr.io/nvidia/pytorch:25.02-py3

ENV DEBIAN_FRONTEND=noninteractive

# UTF-8 locale (required by btop and many terminal tools)
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US:en
ENV LC_ALL=en_US.UTF-8

# Expose all NVIDIA capabilities (compute + utility provides NVML for btop GPU stats)
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=all

# Layer 1: System deps + Node.js
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        git openssh-client graphviz vim curl wget fonts-noto-cjk btop \
        ffmpeg \
        locales && \
    locale-gen en_US.UTF-8 && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# Layer 2: fastai 阶段
# (numpy/scipy/matplotlib/scikit-learn/jupyterlab/notebook 已在基础镜像中，无需重装)
RUN pip install --no-cache-dir \
    fastai fastcore fastdownload fastbook fastkaggle \
    nbdev \
    ipykernel ipywidgets \
    torcheval timm \
    seaborn plotly graphviz dtreeviz \
    sympy networkx

# Layer 3: HuggingFace LLM 阶段
# (einops/safetensors/flash_attn 2.7.3 已在基础镜像中，无需重装)
RUN pip install --no-cache-dir \
    transformers \
    datasets \
    accelerate \
    peft \
    trl \
    bitsandbytes \
    sentencepiece \
    diffusers

# Layer 4: Gradio + Claude Code CLI
RUN pip install --no-cache-dir gradio && \
    npm install -g @anthropic-ai/claude-code

# Layer 5: Clone course repos (placed late — repo updates won't invalidate package cache)
RUN git clone https://github.com/goosmanlei/fastai-course-part2.git /root/fastai-course-part2 && \
    git clone https://github.com/fastai/course22p2.git /root/course22p2 && \
    pip install --no-cache-dir --no-build-isolation --no-deps -e /root/course22p2

# Layer 6: Configuration (matplotlib, Jupyter, git, shell, ipykernel)
RUN mkdir -p /root/.config/matplotlib /root/.jupyter \
        /root/.jupyter/lab/user-settings/@jupyterlab/apputils-extension && \
    printf "font.family : Noto Sans CJK SC\naxes.unicode_minus : False\n" \
        > /root/.config/matplotlib/matplotlibrc && \
    { echo "c.ServerApp.ip = '0.0.0.0'"; \
      echo "c.ServerApp.port = 8888"; \
      echo "c.ServerApp.allow_root = True"; \
      echo "c.ServerApp.token = ''"; \
      echo "c.ServerApp.allow_origin = '*'"; \
      echo "c.ServerApp.allow_remote_access = True"; \
      echo "c.ServerApp.disable_check_xsrf = True"; \
      echo "c.ServerApp.root_dir = '/root/fastai-course-part2'"; \
    } > /root/.jupyter/jupyter_lab_config.py && \
    printf '{\n  "shortcuts": [\n    {\n      "command": "apputils:activate-command-palette",\n      "keys": ["Accel Shift C"],\n      "selector": "body",\n      "disabled": true\n    },\n    {\n      "command": "apputils:activate-command-palette",\n      "keys": ["Accel Alt C"],\n      "selector": "body"\n    }\n  ]\n}\n' \
        > /root/.jupyter/lab/user-settings/@jupyterlab/apputils-extension/shortcuts.jupyterlab-settings && \
    python -m ipykernel install --name llm-learn --display-name "LLM Learn" && \
    git config --global user.email "leiguoguo.ai@gmail.com" && \
    git config --global user.name "goosmanlei" && \
    git config --global alias.co checkout && \
    git config --global alias.br branch && \
    git config --global alias.ci commit && \
    git config --global alias.st status && \
    chsh -s /bin/bash root

EXPOSE 8888

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
CMD ["jupyter", "lab"]
