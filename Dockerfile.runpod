FROM runpod/pytorch:1.0.3-cu1300-torch290-ubuntu2404

ENV DEBIAN_FRONTEND=noninteractive

# UTF-8 locale (required by btop and many terminal tools)
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US:en
ENV LC_ALL=en_US.UTF-8

# Expose all NVIDIA capabilities (compute + utility provides NVML for btop GPU stats)
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=all

# Layer 1: System deps + Node.js
# Switch Ubuntu apt sources to Aliyun mirror (covers both old sources.list and
# Ubuntu 24.04's DEB822 *.sources format) before any apt-get update.
# NodeSource setup runs apt-get update internally; no separate update needed.
RUN grep -rl 'archive.ubuntu.com\|security.ubuntu.com' /etc/apt/ 2>/dev/null | \
    xargs -r sed -i \
        -e 's|http://archive.ubuntu.com/ubuntu|https://mirrors.aliyun.com/ubuntu|g' \
        -e 's|http://security.ubuntu.com/ubuntu|https://mirrors.aliyun.com/ubuntu|g' && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends \
        git openssh-client graphviz vim curl wget fonts-noto-cjk btop \
        ffmpeg gosu sudo python3-venv \
        locales nodejs && \
    locale-gen en_US.UTF-8 && \
    rm -rf /var/lib/apt/lists/*

# Create work user with passwordless sudo
RUN useradd -m -s /bin/bash work && \
    echo "work ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

ENV VIRTUAL_ENV=/home/work/venvs/llm
ENV JUPYTERLAB_SETTINGS_DIR=/home/work/.jupyter/lab/user-settings
ENV MPLCONFIGDIR=/home/work/.config/matplotlib

# Use Aliyun PyPI mirror for all pip installs
ENV PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
ENV PIP_TRUSTED_HOST=mirrors.aliyun.com

# Create a clean venv (no --system-site-packages to avoid version conflicts).
# Then symlink only torch/nvidia/triton packages from the system site-packages into the
# venv — these are pre-compiled against CUDA and expensive to reinstall. Everything else
# (fastai, transformers, …) is pip-installed fresh with full dependency resolution.
# runpod/pytorch images install torch system-wide (no transformer_engine/apex/flash_attn).
RUN gosu work python3 -m venv $VIRTUAL_ENV && \
    gosu work $VIRTUAL_ENV/bin/pip install --no-cache-dir -U pip setuptools wheel && \
    SYSTEM_SP=$(python3 -c "import site; print(site.getsitepackages()[0])") && \
    VENV_SP=$(echo $VIRTUAL_ENV/lib/python*/site-packages) && \
    for item in \
        "$SYSTEM_SP"/torch*  \
        "$SYSTEM_SP"/torchvision* \
        "$SYSTEM_SP"/torchaudio* \
        "$SYSTEM_SP"/triton* \
        "$SYSTEM_SP"/numpy* \
        "$SYSTEM_SP"/nvidia_*; \
    do \
        [ -e "$item" ] && ln -sf "$item" "$VENV_SP/$(basename "$item")" || true; \
    done

# constraints.txt is copied once and shared by all pip layers.
# Changing it invalidates all pip caches — expected when pinned versions change.
# An empty constraints.txt means no pinning (first-run / bootstrap mode).
# To pin: docker run --rm <image> bash -c '$VIRTUAL_ENV/bin/pip freeze --exclude-editable' > constraints.txt
COPY constraints.txt /tmp/constraints.txt

# Layer 2: fastai 阶段
COPY requirements-fastai.in /tmp/
RUN gosu work $VIRTUAL_ENV/bin/pip install --no-cache-dir \
    -c /tmp/constraints.txt -r /tmp/requirements-fastai.in

# Layer 3: HuggingFace LLM + Gradio + Claude Code CLI
COPY requirements-llm.in /tmp/
RUN gosu work $VIRTUAL_ENV/bin/pip install --no-cache-dir \
    -c /tmp/constraints.txt -r /tmp/requirements-llm.in && \
    npm install -g --registry https://registry.npmmirror.com @anthropic-ai/claude-code

# Layer 5: Configuration (matplotlib, Jupyter, git, shell, ipykernel)
# course22p2.pth registered here so venv can import it once cloned at runtime by entrypoint.sh
# Root-only ops run here; work-user config delegated to configure.sh
COPY configure.sh /configure.sh
RUN chmod +x /configure.sh && \
    gosu work $VIRTUAL_ENV/bin/python -c \
        "import site; open(site.getsitepackages()[0]+'/course22p2.pth','w').write('/home/work/course22p2\n')" && \
    git config --system user.email "leiguoguo.ai@gmail.com" && \
    git config --system user.name "goosmanlei" && \
    git config --system alias.co checkout && \
    git config --system alias.br branch && \
    git config --system alias.ci commit && \
    git config --system alias.st status && \
    printf 'source %s/bin/activate\n' "$VIRTUAL_ENV" >> /etc/bash.bashrc && \
    gosu work /configure.sh && \
    rm /configure.sh

EXPOSE 8888

COPY --chmod=755 entrypoint.sh /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
CMD $VIRTUAL_ENV/bin/jupyter lab
