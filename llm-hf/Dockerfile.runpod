ARG BASE_IMAGE=runpod/pytorch:1.0.3-cu1281-torch280-ubuntu2404
FROM ${BASE_IMAGE}
ARG CONSTRAINTS_FILE=constraints-cu1281.txt
ARG TORCH_INDEX_URL=https://download.pytorch.org/whl/cu128
ARG PYTHON_VERSION=3.11

ENV DEBIAN_FRONTEND=noninteractive

# UTF-8 locale (required by many terminal tools)
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US:en
ENV LC_ALL=en_US.UTF-8

# Expose all NVIDIA capabilities
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=all

# Layer 1: System deps + Node.js
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends \
        git openssh-client graphviz vim curl wget fonts-noto-cjk \
        ffmpeg gosu sudo tmux \
        locales nodejs && \
    locale-gen en_US.UTF-8 && \
    rm -rf /var/lib/apt/lists/*

# Create work user with passwordless sudo
RUN useradd -m -s /bin/bash work && \
    echo "work ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

ENV CONDA_ROOT=/home/work/miniforge3
ENV MAMBA_ROOT_PREFIX=/home/work/miniforge3
ENV CONDA_ENV_PATH=/home/work/miniforge3/envs/llm-hf
ENV PATH=/home/work/bin:$PATH
ENV JUPYTERLAB_SETTINGS_DIR=/home/work/.jupyter/lab/user-settings
ENV MPLCONFIGDIR=/home/work/.config/matplotlib
ENV HF_HOME=/home/work/.cache/huggingface

# Layer 2: Install Miniforge3 (mamba) as work user
RUN gosu work wget -q \
        https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh \
        -O /tmp/miniforge.sh && \
    gosu work bash /tmp/miniforge.sh -b -p $CONDA_ROOT && \
    rm /tmp/miniforge.sh && \
    gosu work $CONDA_ROOT/bin/mamba clean -afy

# Per-tag constraints file shared by all pip layers.
# An empty file means no pinning (bootstrap mode).
# To pin: ./build-push-commit.sh --pin
COPY ${CONSTRAINTS_FILE} /tmp/constraints.txt

# Layer 3: Create mamba env + install PyTorch for the target CUDA version
RUN gosu work $CONDA_ROOT/bin/mamba create -n llm-hf python=${PYTHON_VERSION} -y && \
    gosu work $CONDA_ROOT/bin/mamba clean -afy && \
    gosu work $CONDA_ENV_PATH/bin/pip install --no-cache-dir \
        torch torchvision torchaudio \
        --index-url ${TORCH_INDEX_URL} \
        -c /tmp/constraints.txt

# Layer 4: HuggingFace LLM course packages + Claude Code CLI
COPY requirements-hf.in /tmp/
RUN gosu work $CONDA_ENV_PATH/bin/pip install --no-cache-dir \
    -c /tmp/constraints.txt -r /tmp/requirements-hf.in && \
    npm install -g @anthropic-ai/claude-code

# Layer 5: Configuration (matplotlib, Jupyter, git, shell, ipykernel)
COPY --chmod=755 t /home/work/bin/t
COPY .tmux.conf /home/work/.tmux.conf
COPY configure.sh /configure.sh
RUN chmod +x /configure.sh && \
    git config --system user.email "leiguoguo.ai@gmail.com" && \
    git config --system user.name "goosmanlei" && \
    git config --system alias.co checkout && \
    git config --system alias.br branch && \
    git config --system alias.ci commit && \
    git config --system alias.st status && \
    printf 'source %s/etc/profile.d/mamba.sh\nmamba activate llm-hf\n' "$CONDA_ROOT" >> /etc/bash.bashrc && \
    gosu work /configure.sh && \
    rm /configure.sh

EXPOSE 8888

COPY --chmod=755 entrypoint.sh /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
CMD $CONDA_ENV_PATH/bin/jupyter lab
